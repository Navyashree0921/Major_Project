<% layout("/layouts/boilerplate") -%>

    <body>

        <div class="row mt-3">
            <div class="col-8 offset-2">
                <h3>Create a New Listing</h3>
                <br>
                <form action="/listings" method="POST" class="needs-validation" novalidate
                    enctype="multipart/form-data">
                    <div></div>
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" name="listing[title]" placeholder="enter title" class="form-control"
                            required>
                        <div class="valid-feedback">Looks Great!!</div>
                        <div class="invalid-feedback">Invalid title!!</div>

                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea name="listing[description]" placeholder="enter description" class="form-control"
                            required></textarea>
                        <div class="valid-feedback">Looks Great!!</div>
                        <div class="invalid-feedback">Invalid description!!</div>
                    </div>

                    <div class="mb-3">
                        <label for="image" class="form-label">Upload Image</label>
                        <input type="file" name="listing[image]" class="form-control">
                    </div>

                    <div class="row">
                        <div class="col-md-4">
                            <div class="mb-3">
                                <label for="price" class="form-label">Price</label>
                                <input type="number" name="listing[price]" placeholder="enter price"
                                    class="form-control" required>
                                <div class="valid-feedback">Looks Great!!</div>
                                <div class="invalid-feedback">Invalid price!!</div>
                            </div>
                        </div>
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label for="country" class="form-label">Country</label>
                                <input type="text" name="listing[country]" placeholder="enter country"
                                    class="form-control" required>
                                <div class="valid-feedback">Looks Great!!</div>
                                <div class="invalid-feedback">Invalid country name!!</div>
                            </div>
                        </div>
                    </div>


                    <!-- <input type="text" name="description" placeholder="description"> -->
                    <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" name="listing[location]" placeholder="enter location" class="form-control"
                            required>
                        <div class="valid-feedback">Looks Great!!</div>
                        <div class="invalid-feedback">Invalid Location!!</div>
                    </div>

                    <br><br>
                    <button class="btn btn-dark add-btn">Add</button>
                    <br><br>
                </form>
            </div>
        </div>

    </body>